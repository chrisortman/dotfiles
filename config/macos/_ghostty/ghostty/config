font-family = "Berkeley Mono"
#font-family = "Menlo"
font-size = 14

theme = "Monokai Remastered"
#theme = "Monokai Pro Light Sun"
# use ghostty +list-themes, can prefix value with light: and dark:

#cursor-style = block
#shell-integration-features = no-cursor

command = "direct:/Users/cortman/bin/orbterm.sh"

# Don't dim the inactive pane
unfocused-split-opacity = 0.8

keybind = super+shift+l=goto_split:right
keybind = super+shift+h=goto_split:left
keybind = super+shift+k=goto_split:top
keybind = super+shift+j=goto_split:bottom
#keybind = global:ctrl+grave_accent=toggle_quick_terminal


#keybind = shift+enter=text:\n

# ─── tmux-style leader key bindings (ctrl+a prefix) ───────────────────────────

# Splits
keybind = ctrl+a>shift+5=new_split:down
keybind = ctrl+a>shift+quote=new_split:right

# New tab
keybind = ctrl+a>c=new_tab

# Go to tab by number (1–4)
keybind = ctrl+a>h=goto_tab:1
keybind = ctrl+a>j=goto_tab:2
keybind = ctrl+a>k=goto_tab:3
keybind = ctrl+a>l=goto_tab:4

# Flip to previous tab (ctrl+a, ctrl+a)
keybind = ctrl+a>ctrl+a=previous_tab

# Zoom / focus current pane
keybind = ctrl+a>z=toggle_split_zoom

auto-update-channel = tip